{
  "metadata": {
    "description": "Locked native macOS profile for Zoom.",
    "risk": "medium",
    "launcher": "guard-zoom",
    "appBundle": "/Applications/zoom.us.app",
    "status": "locked"
  },
  "workingDirectory": "${GUARD_HOME_DIR}",
  "allowPty": false,
  "system": {
    "allowFileIssueExtension": true,
    "allowMachIssueExtension": true,
    "allowSysctlRead": [
      "hw.model"
    ],
    "allowIokitUserClientClass": [
      "AGXDeviceUserClient",
      "IOHIDParamUserClient"
    ]
  },
  "network": {
    "allowedDomains": [
      "zoom.us",
      "*.zoom.us",
      "zoom.com",
      "*.zoom.com",
      "zoomcdn.com",
      "*.zoomcdn.com",
      "zoomgov.com",
      "*.zoomgov.com"
    ],
    "deniedDomains": [],
    "allowLocalBinding": false,
    "allowLoopbackConnections": false,
    "allowLoopbackHighPorts": false,
    "allowLoopbackPorts": [],
    "allowUnixSockets": [
      "${GUARD_RUN_DIR}",
      "/private/var/run/mDNSResponder",
      "/private/var/run/syslog"
    ],
    "allowMachLookup": [
      "com.apple.SystemConfiguration.configd",
      "com.apple.analyticsd",
      "com.apple.appkit.restoration_storage",
      "com.apple.authd",
      "com.apple.audio.AudioComponentRegistrar",
      "com.apple.audio.SandboxHelper",
      "com.apple.audio.audiohald",
      "com.apple.audio.coreaudiod",
      "com.apple.CARenderServer",
      "com.apple.cmio.registerassistantservice",
      "com.apple.cmio.registerassistantservice.system-extensions",
      "com.apple.CoreServices.coreservicesd",
      "com.apple.controlcenter.statusitems",
      "com.apple.coreservices.appleevents",
      "com.apple.coreservices.launchservicesd",
      "com.apple.coreservices.quarantine-resolver",
      "com.apple.cvmsServ",
      "com.apple.distributed_notifications*",
      "com.apple.dock.server",
      "com.apple.fonts",
      "com.apple.hiservices-xpcservice",
      "com.apple.iconservices",
      "com.apple.iconservices.store",
      "com.apple.inputanalyticsd",
      "com.apple.inputmethodkit.getxpcendpoint",
      "com.apple.inputmethodkit.launchagent",
      "com.apple.inputmethodkit.launcher",
      "com.apple.iohideventsystem",
      "com.apple.logd.events",
      "com.apple.lsd.modifydb",
      "com.apple.pasteboard.*",
      "com.apple.pbs.fetch_services",
      "com.apple.pluginkit.pkd",
      "com.apple.quicklook.ui.helper",
      "com.apple.quicklook.ui.helper.active",
      "com.apple.runningboard*",
      "com.apple.spotlight.IndexAgent",
      "com.apple.tccd",
      "com.apple.tccd.system",
      "com.apple.trustd.agent",
      "com.apple.touchbarserver.mig",
      "com.apple.tsm.uiserver",
      "com.apple.uiintelligencesupport.agent",
      "com.apple.webprivacyd",
      "com.apple.WebKit.GPU",
      "com.apple.WebKit.Networking",
      "com.apple.WebKit.WebContent",
      "com.apple.webinspector",
      "com.apple.ViewBridgeAuxiliary",
      "com.apple.windowmanager.server",
      "com.apple.window_proxies",
      "com.apple.windowserver.active",
      "com.apple.accessibility.mediaaccessibilityd",
      "com.apple.dock.fullscreen",
      "com.apple.gputools.service",
      "com.apple.naturallanguaged",
      "us.zoom.aom.globalmgr.*"
    ]
  },
  "filesystem": {
    "denyRead": [
      "/Users",
      "/Volumes",
      "/Applications",
      "/cores",
      "/home"
    ],
    "allowRead": [
      "/Applications/zoom.us.app",
      "/System/Library/AssetsV2/com_apple_MobileAsset_Font*",
      "${GUARD_RUN_DIR}",
      "${GUARD_HOME_DIR}",
      "${GUARD_TMP_DIR}",
      "${GUARD_REAL_TMPDIR}/us.zoom.xos",
      "${GUARD_REAL_HOME}/Library/Application Support/zoom.us",
      "${GUARD_REAL_HOME}/Library/Caches/us.zoom.xos",
      "${GUARD_REAL_HOME}/Library/HTTPStorages",
      "${GUARD_REAL_HOME}/Library/HTTPStorages/us.zoom.xos.binarycookies",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.Accessibility.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.AppleMultitouchTrackpad.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.ATS.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.HIToolbox.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.CoreGraphics.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.ServicesMenu.Services.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.ExtensionsPreferences.ShareMenu.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.Safari.SandboxBroker.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/.GlobalPreferences.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/.GlobalPreferences_m.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/ByHost/.GlobalPreferences.*.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.assistant.backedup.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.driver.AppleBluetoothMultitouch.mouse.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.driver.AppleBluetoothMultitouch.trackpad.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.mediaaccessibility.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/pbs.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.speech.voice.prefs.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.speech.recognition.AppleSpeechRecognition.prefs.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/com.apple.universalaccess.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/us.zoom.updater.config.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/us.zoom.xos.Hotkey.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/us.zoom.xos.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/ZoomChat.plist",
      "${GUARD_REAL_HOME}/Library/Input Methods",
      "${GUARD_REAL_HOME}/Library/Keyboard Layouts",
      "${GUARD_REAL_HOME}/Library/Logs",
      "${GUARD_REAL_HOME}/Library/Logs/zoom.us",
      "${GUARD_REAL_HOME}/Library/Logs/ZoomPhone",
      "${GUARD_REAL_HOME}/Library/Logs/ZoomPhone/ProcessInfo.plist",
      "${GUARD_REAL_HOME}/Library/Spelling",
      "${GUARD_REAL_HOME}/Library/WebKit",
      "${GUARD_REAL_HOME}/Library/WebKit/us.zoom.xos",
      "/private/tmp/zeb_def_ipc_*",
      "/private/var/folders/**/C/com.apple.IntlDataCache.le",
      "${GUARD_REAL_TMPDIR}/TemporaryItems"
    ],
    "allowWrite": [
      "${GUARD_RUN_DIR}",
      "${GUARD_HOME_DIR}",
      "${GUARD_TMP_DIR}",
      "${GUARD_REAL_TMPDIR}/us.zoom.xos",
      "${GUARD_REAL_HOME}/Library/Application Support/zoom.us",
      "${GUARD_REAL_HOME}/Library/Caches/us.zoom.xos",
      "${GUARD_REAL_HOME}/Library/HTTPStorages",
      "${GUARD_REAL_HOME}/Library/HTTPStorages/us.zoom.xos.binarycookies",
      "${GUARD_REAL_HOME}/Library/Logs",
      "${GUARD_REAL_HOME}/Library/Logs/zoom.us",
      "${GUARD_REAL_HOME}/Library/Logs/ZoomPhone",
      "${GUARD_REAL_HOME}/Library/Preferences/us.zoom.updater.config.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/us.zoom.xos.Hotkey.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/us.zoom.xos.plist",
      "${GUARD_REAL_HOME}/Library/Preferences/ZoomChat.plist",
      "${GUARD_REAL_HOME}/Library/WebKit",
      "${GUARD_REAL_HOME}/Library/WebKit/us.zoom.xos",
      "/private/tmp/zeb_def_ipc_*",
      "/private/var/folders/**/C/com.apple.IntlDataCache.le",
      "${GUARD_REAL_TMPDIR}/TemporaryItems"
    ],
    "denyWrite": [
      "/Volumes",
      "/Applications",
      "/cores",
      "/home",
      ".env",
      ".env.*",
      "secrets/",
      "*.key",
      "*.pem"
    ]
  }
}
